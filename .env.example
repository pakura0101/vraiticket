# =============================================================================
#  VraiTicket — Root environment file
#  Copy to .env:  cp .env.example .env
#  Then edit the values — NEVER commit .env to git.
# =============================================================================

# ── Database credentials ─────────────────────────────────────────────────────
POSTGRES_DB=vraiticket_db
POSTGRES_USER=vraiticket_user
POSTGRES_PASSWORD=change_me_use_a_strong_password

# ── JWT secret ───────────────────────────────────────────────────────────────
# Generate:  python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_ME_TO_A_VERY_LONG_RANDOM_STRING_AT_LEAST_64_CHARS

# ── Auth settings ────────────────────────────────────────────────────────────
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Application ──────────────────────────────────────────────────────────────
DEFAULT_SLA_HOURS=24

# ── First admin account (seeded on first startup) ────────────────────────────
FIRST_ADMIN_EMAIL=admin@vraiticket.io
FIRST_ADMIN_PASSWORD=Admin@12345

# ── Frontend API URL ─────────────────────────────────────────────────────────
# With Nginx reverse proxy (default): use a relative path — same origin, no CORS
NEXT_PUBLIC_API_URL=/api/v1
#
# Without Nginx (direct ports): use the full server URL
# NEXT_PUBLIC_API_URL=http://your-server-ip:8000/api/v1

# ── Exposed HTTP port ─────────────────────────────────────────────────────────
HTTP_PORT=80
# HTTPS_PORT=443
