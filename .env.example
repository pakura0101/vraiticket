# ═══════════════════════════════════════════════════════════
#  VraiTicket — Docker Compose environment
#  Copy this file to .env and fill in the values.
#  NEVER commit the real .env to version control.
# ═══════════════════════════════════════════════════════════

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=vraiticket_db
POSTGRES_USER=vraiticket_user
POSTGRES_PASSWORD=change_me_strong_password_here

# ── Exposed ports ────────────────────────────────────────────
API_PORT=8000
FRONTEND_PORT=3000

# ── Frontend public API URL ──────────────────────────────────
# This is baked into the Next.js build at build time.
# Must be the URL the BROWSER uses to reach the API.
# • Local dev:      http://localhost:8000/api/v1
# • Production:     https://api.yourdomain.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
