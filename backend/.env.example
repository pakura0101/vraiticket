# =============================================================================
#  VraiTicket — Backend Environment Variables
#  Copy this file to .env and fill in all required values before starting.
# =============================================================================

# ── Application ───────────────────────────────────────────────
APP_NAME=VraiTicket
# Set to "development" locally to enable DEBUG mode, Swagger UI, and open CORS
APP_ENV=production
DEBUG=false

# ── Database ──────────────────────────────────────────────────
# Example: postgresql://user:password@localhost:5432/vraiticket_db
DATABASE_URL=postgresql://vraiticket_user:CHANGE_ME@localhost:5432/vraiticket_db

# ── JWT ───────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_strong_random_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Redis / Celery ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── SLA ───────────────────────────────────────────────────────
DEFAULT_SLA_HOURS=24

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (ignored when DEBUG=true)
# Example: https://app.vraiticket.io,https://admin.vraiticket.io
ALLOWED_ORIGINS=https://your-frontend-domain.com

# ── First Admin Account ───────────────────────────────────────
# REQUIRED — no defaults exist. The app will refuse to start without these.
# These values are used ONCE at first boot to seed the admin account.
# Change the password immediately after first login.
FIRST_ADMIN_EMAIL=admin@your-domain.com
FIRST_ADMIN_PASSWORD=CHANGE_ME_use_a_strong_password
