# ─── Application ───────────────────────────────────────────────
APP_NAME=VraiTicket
APP_ENV=development          # development | production
DEBUG=true

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://vraiticket_user:strongpassword@localhost:5432/vraiticket_db

# ─── JWT ───────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_TO_A_VERY_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Redis / Celery ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── SLA defaults (minutes) ────────────────────────────────────
DEFAULT_SLA_HOURS=24

# ─── First admin (seeded on startup) ───────────────────────────
FIRST_ADMIN_EMAIL=admin@vraiticket.io
FIRST_ADMIN_PASSWORD=Admin@12345
